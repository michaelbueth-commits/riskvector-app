# RISKVECTOR.PROD - Production Environment Variables
# ================================================

# APPLICATION CONFIGURATION
NEXT_PUBLIC_APP_URL=https://riskvector.app
NEXT_PUBLIC_APP_NAME="RiskVector Professional"
NEXT_PUBLIC_VERSION="1.0.0"

# API KEYS (REAL PRODUCTION KEYS REQUIRED)
NEWSAPI_API_KEY=YOUR_PRODUCTION_NEWSAPI_KEY_HERE
INTERPOL_API_KEY=YOUR_PRODUCTION_INTERPOL_KEY_HERE
UN_OCHA_API_KEY=YOUR_PRODUCTION_UN_OCHA_KEY_HERE

# ANALYTICS & MONITORING (OPTIONAL)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxx.ingest.sentry.io/xxxxxxxxxxxx

# SECURITY (PRODUCTION)
NEXTAUTH_SECRET=YOUR_SUPER_SECRET_RANDOM_STRING_HERE
NEXTAUTH_URL=https://riskvector.app

# DATABASE (FUTURE USE)
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://user:password@host:6379/0

# CDN & PERFORMANCE (VERCEL)
VERCEL_URL=https://riskvector.app
VERCEL_ENV=production