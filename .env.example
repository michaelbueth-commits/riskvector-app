# ================================================================
# RISKVECTOR PRODUCTION CONFIGURATION
# ================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ================================================================
# APPLICATION SETTINGS
# ================================================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_URL=https://riskvector.app

# ================================================================
# SECURITY & MONITORING
# ================================================================
# Application secret for Next.js
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=https://riskvector.app

# Analytics (optional - remove if not needed)
NEXT_PUBLIC_UMAMI_ID=your-umami-id
UMAMI_URL=https://your-umami-instance.com

# ================================================================
# API KEYS - CRITICAL FOR FUNCTIONALITY
# ================================================================

# --- ACLED API (Armed Conflict Location & Event Data) ---
# Get your API credentials: https://acleddata.com/dashboard
ACLED_API_KEY=your-acled-api-key-here
ACLED_CLIENT_ID=acled
ACLED_CLIENT_SECRET=your-acled-client-secret

# --- WHO GHO API (World Health Organization) ---
# Disease outbreak indicator: MENING_3
# No API key required - public data
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api
WHO_DISEASE_INDICATOR=MENING_3

# --- World News API ---
# Get your API key: https://api.worldnewsapi.com/pricing
WORLD_NEWS_API_KEY=your-world-news-api-key-here
WORLD_NEWS_BASE_URL=https://api.worldnewsapi.com

# --- MeteoAlarm API (European Weather Warnings) ---
# Free tier - no API key required
METEOALARM_BASE_URL=https://api.meteoalarm.org

# --- NINA API (German Civil Protection) ---
# Free tier - no API key required  
NINA_BASE_URL=https://warnung.bund.de/api31

# --- SPC PDH.stat API (Pacific Community) ---
# Free tier - no API key required
SPC_BASE_URL=https://stats-nsi-stable.pacificdata.org/rest

# --- Ambee Natural Disasters API ---
# Get your API key: https://www.ambeedata.com
AMBBE_API_KEY=your-ambee-api-key-here

# --- BBC News API ---
# Free tier - no API key required
BBC_NEWS_BASE_URL=https://bbc-news-api.vercel.app

# ================================================================
# DATABASE & CACHING
# ================================================================
# Redis for caching (optional)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ================================================================
# EXTERNAL SERVICES
# ================================================================

# Geocoding (optional - default service is free)
GEOCODING_API_KEY=your-geocoding-api-key

# Email service for alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ================================================================
# MONITORING & LOGGING
# ================================================================

# Health check endpoint
HEALTH_CHECK_URL=https://riskvector.app/api/health

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# Error tracking (optional - Sentry)
SENTRY_DSN=your-sentry-dsn-here

# ================================================================
# BUSINESS CONFIGURATION
# ================================================================

# Pricing and billing
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# App configuration
APP_NAME=RiskVector
APP_SUPPORT_EMAIL=support@riskvector.app
APP_ADMIN_EMAIL=admin@riskvector.app

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Data retention (in days)
DATA_RETENTION_DAYS=365

# ================================================================
# SECURITY HARDENING
# ================================================================

# CORS (Comma-separated origins)
CORS_ORIGINS=https://riskvector.app,https://www.riskvector.app

# API rate limiting
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=900000

# Security headers
HELMET_ENABLED=true
CSP_ENABLED=true

# ================================================================
# NOTES
# ================================================================
# 1. Fill in all required API keys before deploying
# 2. Test all API endpoints in staging before production
# 3. Keep this file secure and never commit actual credentials
# 4. Regularly rotate API keys and secrets
# 5. Monitor API usage and rate limits
# 6. Implement backup strategies for critical data

# LAST UPDATED: 2026-03-08
# STATUS: Ready for deployment with actual API keys